  "soul": {
    "name": "de BigBos",
    "persona": "A sharp, witty AI assistant that's direct and concise.",
    "tone": "professional but casual",
    "greeting": "Hey! Ready to ship something awesome?",
    "constraints": [],
    "custom_prompt": ""
  },
  "skills": {
    "enabled": true,
    "paths": [
      ".debigbos/skills"
    ],
    "auto_load": [],
    "disabled_skills": []
  },
  "memory": {
    "enabled": true,
    "db_path": ".debigbos/memory.db",
    "embedding_model": "all-MiniLM-L6-v2",
    "max_short_term": 50,
    "compaction_threshold": 0.8,
    "vector_search_k": 5,
    "session_load_limit": 200,
    "auto_load_session": false,
    "session_keep_days": 0,
    "resume_mode": "full",
    "save_reasoning": true,
    "compaction": {
      "auto": true,
      "threshold": 0.8,
      "keep": 10,
      "prune": false,
      "reserved": 10000
    }
  },
  "agents": {
    "explore": {
      "name": "explore",
      "description": "Read-only codebase explorer. Searches files, patterns, and code.",
      "model": "gpt-4o-mini",
      "system_prompt": "You are a code explorer. Search and read files only. Never write or edit. Return findings concisely.",
      "max_steps": 10,
      "tools": [
        "read",
        "glob",
        "grep",
        "webfetch"
      ]
    },
    "planner": {
      "name": "planner",
      "description": "Planning agent. Breaks down complex tasks before execution.",
      "model": "gpt-4o",
      "system_prompt": "You are a planner. Analyze the task and create a clear step-by-step plan. Think before coding.",
      "max_steps": 8,
      "tools": [
        "read",
        "glob",
        "grep",
        "todo"
      ]
    },
    "reviewer": {
      "name": "reviewer",
      "description": "Code reviewer. Reviews code for bugs, style, and security.",
      "model": "gpt-4o-mini",
      "system_prompt": "You are a code reviewer. Find bugs, style issues, and security problems. Be thorough but concise.",
      "max_steps": 5,
      "tools": [
        "read",
        "glob",
        "grep"
      ]
    }
  },
  "max_tool_steps": 20,
  "reasoning_budget": 16000,
  "auto_approve": false,
  "snapshot": true,
  "mode": "build"
}